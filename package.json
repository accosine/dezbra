{
  "name": "phaser-vite-ts-boilerplate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "format": "prettier --write .",
    "lint": "eslint",
    "ok": "pnpm run format && pnpm run lint && pnpm run test && pnpm run typecheck && pnpm run build",
    "preview": "vite preview",
    "test": "pnpm run test:unit:chromium && pnpm run test:unit:firefox && pnpm run test:unit:webkit && pnpm run test:e2e",
    "test:e2e": "playwright test",
    "test:unit:chromium": "vitest run --browser=chromium --coverage ",
    "test:unit:firefox": "vitest run --browser=firefox",
    "test:unit:webkit": "vitest run --browser=webkit",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-tsdoc": "0.5.2",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "phaser": "4.1.0",
    "playwright": "1.60.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
